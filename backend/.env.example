# MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=ristobrain_db

# Security
JWT_SECRET_KEY=your-secret-key-change-in-production
CORS_ORIGINS=*

# App Configuration
APP_URL=https://staging.ristobrain.app

# Currency & Locale Defaults
DEFAULT_CURRENCY=EUR
DEFAULT_LOCALE=it-IT
SUPPORTED_CURRENCIES=EUR,USD
SUPPORTED_LOCALES=en-US,it-IT
MONEY_DECIMALS=2

# Email Configuration (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=RistoBrain <no-reply@ristobrain.app>

# Migration Control
MIGRATION_MONETARY_V1=false
