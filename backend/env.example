# --- Application ---
ENV=development
DEBUG=true
LOG_LEVEL=INFO
ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
APP_URL=http://localhost:3000

# --- Database ---
MONGO_URI=mongodb://mongo:27017/ristobrain
MONGO_DB_NAME=ristobrain

# --- Auth / JWT ---
JWT_SECRET=changeme
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Email ---
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=RistoBrain <no-reply@ristobrain.app>

# --- Storage ---
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=/data/storage

# If using S3/MinIO:
# S3_ENDPOINT_URL=http://minio:9000
# S3_REGION=eu-west-1
# S3_ACCESS_KEY=minio
# S3_SECRET_KEY=minio123
# S3_BUCKET=ristobrain

# --- Locale / Currency ---
DEFAULT_CURRENCY=EUR
DEFAULT_LOCALE=it-IT
SUPPORTED_CURRENCIES=EUR,USD
SUPPORTED_LOCALES=en-US,it-IT
